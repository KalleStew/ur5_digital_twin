<?xml version="1.0"?>
<robot name="ur57_arm">

    <link name="world"/>
    <joint name="world_joint" type="fixed">
        <parent link="world"/>
        <child link="base_link"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <link name="base_link">
        <visual><geometry><mesh filename="package://my_arm_description/meshes/visual/ur5_base.stl"/></geometry></visual>
        <collision><geometry><mesh filename="package://my_arm_description/meshes/collision/ur5_base.stl"/></geometry></collision>
    </link>

    <joint name="shoulder_pan_joint1" type="revolute">
        <parent link="base_link"/>
        <child link="shoulder_link1"/>
        <origin xyz="0 0 0.089159" rpy="0 0 0"/>
        <axis xyz="0 0 1"/>
        <limit effort="150.0" velocity="3.14159" lower="-6.28318" upper="6.28318"/>
    </joint>
    <link name="shoulder_link1">
        <visual><geometry><mesh filename="package://my_arm_description/meshes/visual/ur5_shoulder.stl"/></geometry></visual>
        <collision><geometry><mesh filename="package://my_arm_description/meshes/collision/ur5_shoulder.stl"/></geometry></collision>
    </link>

    <joint name="shoulder_pan_joint" type="revolute">
        <parent link="shoulder_link1"/>
        <child link="shoulder_link"/>
        <origin xyz="0 0 0.05" rpy="0 0 0"/> 
        <axis xyz="0 0 1"/>
        <limit effort="150.0" velocity="3.14159" lower="-6.28318" upper="6.28318"/>
    </joint>
    <link name="shoulder_link">
        <visual><geometry><mesh filename="package://my_arm_description/meshes/visual/ur5_shoulder.stl"/></geometry></visual>
        <collision><geometry><mesh filename="package://my_arm_description/meshes/collision/ur5_shoulder.stl"/></geometry></collision>
    </link>

    <joint name="shoulder_lift_joint" type="revolute">
        <parent link="shoulder_link"/>
        <child link="upper_arm_link"/>
        <origin xyz="0 0.13585 0" rpy="0 1.57079632679 0"/>
        <axis xyz="-1 0 0"/>
        <limit effort="150.0" velocity="3.14159" lower="-6.28318" upper="6.28318"/>
    </joint>
    <link name="upper_arm_link">
        <visual><geometry><mesh filename="package://my_arm_description/meshes/visual/ur5_upperarm.stl"/></geometry></visual>
        <collision><geometry><mesh filename="package://my_arm_description/meshes/collision/ur5_upperarm.stl"/></geometry></collision>
    </link>

    <joint name="elbow_joint" type="revolute">
        <parent link="upper_arm_link"/>
        <child link="forearm_link"/>
        <origin xyz="0 -0.1197 0.425" rpy="0 0 0"/>
        <axis xyz="-1 0 0"/>
        <limit effort="150.0" velocity="3.14159" lower="-3.14159" upper="3.14159"/>
    </joint>
    <link name="forearm_link">
        <visual><geometry><mesh filename="package://my_arm_description/meshes/visual/ur5_forearm.stl"/></geometry></visual>
        <collision><geometry><mesh filename="package://my_arm_description/meshes/collision/ur5_forearm.stl"/></geometry></collision>
    </link>

    <joint name="wrist_1_joint" type="revolute">
        <parent link="forearm_link"/>
        <child link="wrist_1_link"/>
        <origin xyz="0 0 0.39225" rpy="0 1.57079632679 0"/>
        <axis xyz="-1 0 0"/>
        <limit effort="28.0" velocity="3.14159" lower="-6.28318" upper="6.28318"/>
    </joint>
    <link name="wrist_1_link">
        <visual><geometry><mesh filename="package://my_arm_description/meshes/visual/ur5_wrist1.stl"/></geometry></visual>
        <collision><geometry><mesh filename="package://my_arm_description/meshes/collision/ur5_wrist1.stl"/></geometry></collision>
    </link>

    <joint name="wrist_2_joint" type="revolute">
        <parent link="wrist_1_link"/>
        <child link="wrist_2_link"/>
        <origin xyz="0 0.093 0" rpy="0 0 0"/>
        <axis xyz="0 0 1"/>
        <limit effort="28.0" velocity="3.14159" lower="-6.28318" upper="6.28318"/>
    </joint>
    <link name="wrist_2_link">
        <visual><geometry><mesh filename="package://my_arm_description/meshes/visual/ur5_wrist2.stl"/></geometry></visual>
        <collision><geometry><mesh filename="package://my_arm_description/meshes/collision/ur5_wrist2.stl"/></geometry></collision>
    </link>

    <joint name="wrist_3_joint" type="revolute">
        <parent link="wrist_2_link"/>
        <child link="wrist_3_link"/>
        <origin xyz="0 0 0.09465" rpy="0 0 0"/>
        <axis xyz="-1 0 0"/>
        <limit effort="28.0" velocity="3.14159" lower="-6.28318" upper="6.28318"/>
    </joint>
    <link name="wrist_3_link">
        <visual><geometry><mesh filename="package://my_arm_description/meshes/visual/ur5_wrist3.stl"/></geometry></visual>
        <collision><geometry><mesh filename="package://my_arm_description/meshes/collision/ur5_wrist3.stl"/></geometry></collision>
    </link>

    <joint name="ee_fixed_joint" type="fixed">
        <parent link="wrist_3_link"/>
        <child link="ee_link"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>
    <link name="ee_link"/>

    <joint name="wrist_3_link_tool0_fixed_joint" type="fixed">
        <parent link="wrist_3_link"/>
        <child link="tool0"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>
    <link name="tool0"/>

    <ros2_control name="IgnitionSystem" type="system">
        <hardware>
            <plugin>ign_ros2_control/IgnitionSystem</plugin>
        </hardware>
        <joint name="shoulder_pan_joint1">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="shoulder_pan_joint">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="shoulder_lift_joint">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="elbow_joint">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="wrist_1_joint">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="wrist_2_joint">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="wrist_3_joint">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
    </ros2_control>

    <gazebo>
        <plugin filename="ign_ros2_control-system" name="ign_ros2_control::IgnitionROS2ControlPlugin">
            <parameters>$(find my_arm_description)/config/controllers.yaml</parameters>
        </plugin>
    </gazebo>
</robot>